<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <title>List of items</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .header-nav {
            background-color: #00c853;
            padding: 10px;
            text-align: center;
        }

        .header-nav a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
            font-size: 1.2rem;
            font-weight: 500;
        }

        .table-container {
            max-width: 800px;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
        }

        .btn-confirm {
            background-color: #c2185b;
            border: none;
            border-radius: 12px;
            padding: 10px 40px;
            font-size: 1.2rem;
            color: white;
        }
    </style>
</head>

<body class="bg-light text-center">

    <div class="header-nav mb-5">
        <a href="/">Menu</a>
        <a href="/cart">Cart</a>
    </div>

    <div class="container">
        <h1 class="fw-bold mb-4">List of items</h1>

        <div class="table-container shadow-sm">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th width="10%">#</th>
                        <th width="50%">Item</th>
                        <th width="20%">Qty</th>
                        <th width="20%">Price</th>
                    </tr>
                </thead>
                <tbody>
                    <% cart.forEach((item, index)=> { %>
                        <tr>
                            <td>
                                <%= index + 1 %>
                            </td>
                            <td>
                                <%= item.name %>
                            </td>
                            <td>1</td>
                            <td>
                                <%= item.price %>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>

            <h3 class="fw-bold mt-4">total price : <%= total %> THB</h3>
            <button onclick="location.href='/confirm'" class="btn btn-confirm mt-3">Confirm Order</button>
        </div>
    </div>

</body>

</html>