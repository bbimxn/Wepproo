<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <title>AUNTIE-AUN Restaurant</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .header-nav {
            background-color: #00c853;
            padding: 10px;
            text-align: center;
        }

        .header-nav a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
            font-size: 1.2rem;
            font-weight: 500;
        }

        .food-card {
            border-radius: 15px;
            border: none;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            height: 100%;
        }

        .food-img {
            height: 200px;
            object-fit: cover;
        }

        .price-text {
            color: #f44336;
            font-weight: bold;
        }

        .btn-add {
            background-color: #007bff;
            border-radius: 8px;
            border: none;
            padding: 5px 15px;
        }
    </style>
</head>

<body class="bg-light">

    <div class="header-nav mb-4">
        <a href="/">Menu</a>
        <a href="/cart">Cart</a>
    </div>

    <div class="container">
        <h2 class="text-center fw-bold mb-4">AUNTIE-AUN Restaurant</h2>
        <div class="row row-cols-1 row-cols-md-3 g-4">
            <% data.forEach(item=> { %>
                <div class="col">
                    <div class="card food-card">
                        <img src="<%= item.image_url %>" class="card-img-top food-img">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">
                                <%= item.name %>
                            </h5>
                            <p class="card-text text-muted small">
                                <%= item.description %>
                            </p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="price-text">
                                    <%= item.price %> THB
                                </span>
                                <button
                                    onclick="location.href='/add/<%= item.product_id %>/<%= encodeURIComponent(item.name) %>/<%= item.price %>'"
                                    class="btn btn-primary btn-add">Add to Cart</button>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
        </div>
    </div>

</body>

</html>